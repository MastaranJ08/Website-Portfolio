---
import '../styles/global.css'
import '../styles/extra.css'
import MovingCosmicBackground from '../components/MovingCosmicBackground'

const { title = 'Portfolio' } = Astro.props
const pathname = Astro.url.pathname.replace(/\/+$/, '') || '/'

const navItemClass = (href: string) =>
  pathname === href.replace(/\/+$/, '') || (href === '/' && pathname === '/')
    ? 'pointer-events-auto text-white'
    : 'pointer-events-auto text-gray-300'
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="bg-cyberbg">
    <div class="fixed inset-0 z-0 pointer-events-none" aria-hidden="true">
      <MovingCosmicBackground client:load />
    </div>

    <div class="relative z-10">
      <header class="sticky top-0 z-30 border-b border-white/10 bg-slate-950/60 backdrop-blur-xl pointer-events-auto">
        <div class="container flex items-center justify-between py-4">
          <a href="/" class="font-display text-xl tracking-tight text-white pointer-events-auto">
            Jesson.Oktafian Jayawinata
          </a>
          <nav class="flex flex-wrap justify-end gap-x-4 gap-y-2 text-sm text-gray-300 pointer-events-auto sm:gap-x-6">
            <a href="/" class={navItemClass('/')} aria-current={pathname === '/' ? 'page' : undefined}>Home</a>
            <a href="/about/" class={navItemClass('/about')} aria-current={pathname === '/about' ? 'page' : undefined}>About</a>
            <a href="/projects/" class={navItemClass('/projects')} aria-current={pathname === '/projects' ? 'page' : undefined}>Projects</a>
            <a href="/playground/" class={navItemClass('/playground')} aria-current={pathname === '/playground' ? 'page' : undefined}>Playground</a>
            <a href="/contact/" class={navItemClass('/contact')} aria-current={pathname === '/contact' ? 'page' : undefined}>Contact</a>
          </nav>
        </div>
      </header>

      <main class="relative z-10 pointer-events-auto">
        <slot />
      </main>

      <footer class="py-12 text-center text-sm text-gray-400 pointer-events-auto">
        © 2026 • Built with Astro + Solid + Bun
      </footer>
    </div>
  </body>
</html>
